# =============================================================================
# PeerDB ETL Pipeline — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# NEVER commit the real .env file to git.
#
#   cp .env.example .env
#   nano .env
# =============================================================================

# ── PostgreSQL Source ─────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=vipani_devpy_final_stg
PG_USER=postgres
PG_PASSWORD=your_postgres_password

# PeerDB dedicated replication user (created by scripts/pg_replication_setup.sql)
PEERDB_REPL_USER=peerdb_replicator
PEERDB_REPL_PASSWORD=your_peerdb_repl_password

# PeerDB internal catalog password (docker-compose)
PEERDB_CATALOG_PASSWORD=change_me_catalog_password

# ── ClickHouse Destination ────────────────────────────────────────────────
CH_HOST=localhost
CH_PORT=8123
CH_DATABASE=vipaniv2
CH_USER=default
CH_PASSWORD=

# ── PeerDB Server ─────────────────────────────────────────────────────────
PEERDB_API_URL=http://localhost:8113
PEERDB_LOG_LEVEL=info

# ── Aggregation Refresh Scheduler ────────────────────────────────────────
AGG_INTERVAL=600          # seconds between agg_daily_* refresh (default 10 min)
SNAP_INTERVAL=3600        # seconds between snapshot_* refresh (default 60 min)

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Optional: MinIO/S3 staging for ClickHouse CDC
PEERDB_MINIO_ACCESS_KEY=_peerdb_minioadmin
PEERDB_MINIO_SECRET_KEY=_peerdb_minioadmin
PEERDB_S3_BUCKET_NAME=peerdbbucket
